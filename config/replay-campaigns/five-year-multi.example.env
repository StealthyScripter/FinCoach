DATASET_MANIFEST=/data/fincoach/datasets/fx-metals-five-year/manifest.json
DATASET_OUTPUT=/data/fincoach/datasets/fx-metals-five-year
DATASET_PROVIDER=oanda
DATASET_ENVIRONMENT=practice
PRICE_COMPONENT=bid_ask
COMPRESSION=gzip
DOWNLOAD_CONCURRENCY=1
OUTPUT_DIR=/var/lib/fincoach/replay/five-year-multi
SYMBOLS=EUR_USD,GBP_USD,USD_JPY,XAU_USD
TIMEFRAMES=15m,1h
START_TIME=2020-01-01T00:00:00.000Z
END_TIME=2024-12-31T23:59:59.999Z
SEED=42
WORKER_COUNT=2
CHECKPOINT_INTERVAL=25000
BATCH_SIZE=1000
RESTART_SCHEDULE=
