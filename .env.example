# App
PORT=
NODE_ENV=
APP_BASE_URL=
MARKETPILOT_RUN_MODE=demo_observation
MARKETPILOT_DEMO_ONLY=true

# Database
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=fincoach-postgres
POSTGRES_RESTART_POLICY=unless-stopped
POSTGRES_USER=wendot
POSTGRES_PASSWORD=change-me
POSTGRES_DB=FinCoach
POSTGRES_HOST_PORT=5434
POSTGRES_CONTAINER_PORT=5432
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_WAL_BUFFERS=16MB
POSTGRES_DEFAULT_STATISTICS_TARGET=100
POSTGRES_RANDOM_PAGE_COST=1.1
POSTGRES_WORK_MEM=4MB
POSTGRES_HEALTHCHECK_INTERVAL=10s
POSTGRES_HEALTHCHECK_TIMEOUT=5s
POSTGRES_HEALTHCHECK_RETRIES=5
POSTGRES_HEALTHCHECK_START_PERIOD=10s
DATABASE_URL=postgresql://wendot:change-me@localhost:5434/FinCoach

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_CHAT_ID=
TELEGRAM_SIGNAL_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_NOTIFICATIONS_ENABLED=true
TELEGRAM_SIGNALS_ENABLED=true
TELEGRAM_DAILY_SUMMARY_HOUR_UTC=22
TELEGRAM_WEEKLY_SUMMARY_DAY=0
TELEGRAM_WEEKLY_SUMMARY_HOUR_UTC=22
TELEGRAM_MARKET_SESSION_ALERTS=true
TELEGRAM_MIN_SIGNAL_CONFIDENCE=75
TELEGRAM_MIN_SIGNAL_EVIDENCE_SCORE=0.75
TELEGRAM_SIGNAL_COOLDOWN_MINUTES=60
TELEGRAM_SIGNAL_SIGNING_SECRET=

# AI
